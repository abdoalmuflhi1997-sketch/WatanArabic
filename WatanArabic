<script>
// Mobile menu
function tgm(){document.getElementById('nl').classList.toggle('on')}

// Search
function s(){const v=document.getElementById('si').value;if(v)alert('البحث عن: '+v)}
document.getElementById('si').addEventListener('keypress',e=>{if(e.key==='Enter')s()})

// Reading mode
function tgrm(){document.body.classList.toggle('rm');localStorage.setItem('rm',document.body.classList.contains('rm')?'1':'0')}
if(localStorage.getItem('rm')==='1')document.body.classList.add('rm')

// Share toggle
function tgsh(){document.getElementById('shm').classList.toggle('on')}

// Bookmark
const bm=JSON.parse(localStorage.getItem('bm')||'[]')
function bk(el,id){const i=bm.indexOf(id);if(i>-1){bm.splice(i,1);el.classList.remove('on');el.querySelector('i').className='far fa-bookmark'}else{bm.push(id);el.classList.add('on');el.querySelector('i').className='fas fa-bookmark'}localStorage.setItem('bm',JSON.stringify(bm))}
document.querySelectorAll('.bk').forEach(b=>{const id=+b.closest('.nc').dataset.id;if(bm.includes(id)){b.classList.add('on');b.querySelector('i').className='fas fa-bookmark'}})

// Share article
function sh(el,id){const t=el.closest('.nc').querySelector('.nct').textContent;const u=encodeURIComponent(location.href+'#article-'+id);const tu=encodeURIComponent(t);window.open('https://wa.me/?text='+tu+'%20'+u,'_blank')}

// Scroll animation
const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.style.opacity='1';x.target.style.transform='translateY(0)';obs.unobserve(x.target)}})},{threshold:.1})
document.querySelectorAll('.nc,.alc,.opc,.mrc,.rrc').forEach(el=>{el.style.opacity='0';el.style.transform='translateY(20px)';el.style.transition='opacity .5s ease,transform .5s ease';obs.observe(el)})

// Header shadow
window.addEventListener('scroll',()=>{document.querySelector('.mh').style.boxShadow=window.scrollY>40?'0 4px 20px rgba(0,0,0,.12)':'0 2px 12px rgba(0,0,0,.06)'})

// Close menus on outside click
document.addEventListener('click',e=>{if(!e.target.closest('.shp'))document.getElementById('shm').classList.remove('on');if(!e.target.closest('.mn'))document.getElementById('nl').classList.remove('on')})

// Stagger animations
const st=['.nc','.mrc','.opc','.rrc'];st.forEach(s=>{document.querySelectorAll(s).forEach((el,i)=>{el.style.animationDelay=(i*.08)+'s'})})
</script>
